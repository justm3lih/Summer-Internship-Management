# ==========================================
# Summer Internship Management - .gitignore
# ==========================================

# ----- İşletim Sistemi Geçici Dosyaları (OS Temp Files) -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
[Dd]esktop.ini

# ----- Ofis & Doküman Geçici Dosyaları (Office/Word Temp Files) -----
~$*
*.tmp
*.temp

# ----- Editörler & IDE'ler (Editors & IDEs) -----
.vs/
.vscode/
*.suo
*.user
*.userprefs
*.sln.docstates
.idea/
*.iml
*.swp
*~

# ----- Paket Yöneticileri & Bağımlılıklar (Dependencies) -----
node_modules/
jspm_packages/
web_modules/
.npm/
.yarn/
.pnpm-store/
package-lock.json.log
yarn-error.log
pnpm-debug.log

# ----- Loglar & Raporlar (Logs & Reports) -----
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# ----- Backend (.NET Core / C#) -----
# Derleme çıktıları (Build outputs)
[Bb]in/
[Oo]bj/

# Local DB & SQL Server LocalDB
*.db
*.db-journal
*.sqlite
*.sqlite3
*.mdf
*.ldf

# Local environment & secrets
backend/appsettings.Local.json
backend/appsettings.Development.json.user
backend/uploads/
backend/secrets.json
.microsoft.visualstudio.web.solr/

# ----- Frontend (Next.js / Node) -----
# Build & Output
.next/
out/
dist/
build/
.cache/

# Ortam değişkenleri (Environment Variables - Keep .env.example but ignore local keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ----- Projeye Özel Geçici Dosyalar (Project-specific Temp Files) -----
found.txt
found2.txt
xx.txt
scratch/
_ENGI402_format_extract.txt
~$NGI402_format_extract.txt
diagram.html
*diagram*
slide6.html
BACKLOG.md
restore.ps1
presentation.html
CALISTIRMA.md
PLACEHOLDERS.txt
Juri_Hazirlik_Sorulari.doc
Juri_Hazirlik_Sorulari_v2.doc
Juri_Ceyda_Hazirlik_Sorulari.doc
Juri_Ceyda_Kod_Sorulari.doc
Juri_Backend_Kod_Sorulari.doc










